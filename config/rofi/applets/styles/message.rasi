@import "colors.rasi"

* {
    background-color: @background;
    text-color:       @foreground;
    font:             "JetBrains Mono Nerd Font 12";
}

window {
    width:          380px;
    padding:        30px;
    border:         1px;
    border-radius:  20px;
    border-color:   @accent;
    background-blur: true;
    transparency:   "real";
    location:       center;
    y-offset:       -20px;
}

entry {
    expand:     true;
    text-color: @accent;
}
