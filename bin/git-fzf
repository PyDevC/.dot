#!/usr/bin/env bash

load_all="0"
Style="+m --height 50% --style full --input-label 'Destination' --preview"
REPOS=()

select_repo() {
    while [ $# -gt 0 ]; do
        REPOS+="$(dirname $(find $1 -name ".git" -type d))"
        shift 1
    done
}

repo_selection(){
    local selected
    selected=$( printf "$REPOS" | fzf $Style 'tree -C {}')

    if [ -z $selected ]; then
        return
    fi

    echo $selected 
}

git_fnc(){
    git_cmd_a=( ["branch_commit"]="branch -vva" )
    git_cmd=("status" "status -uno" "log" "branch -vva" "commit" "add" "config") # simple git commands
    selected=$( printf '%s\n' "${git_cmd[@]}" | fzf $Style 'tree -C {}')
    echo $selected
}


while [[ $# -gt 0 ]];do
    if [[ $1 == "--load-all" ]];then
        load_all="1"
    fi
    shift
done


if [[ $load_all == "1" ]];then
    for repo in $(select_repo $HOME/personal $HOME/work); do
        echo $REPOS
        git -C $REPOS --no-pager branch -vva 
    done
    exit 0
fi

select_repo $HOME/work $HOME/personal/github

repo="$(repo_selection)"
cmd="cmd"

while [ ! -z "$cmd" ]; do
    cmd=`git_fnc`

    if [[ -z "$repo" || -z "$cmd" ]]; then
        exit 0
    fi

    printf "\n git -C $repo $cmd"
    git -C $repo $cmd
done
